{{> head}}
{{> header}}

<div class="auth-page">
  <h1>Create account</h1>
  <p class="subheading">Join Serenity Yoga & Mindfulness Studio</p>

  {{#error}}
  <div class="alert alert-error">{{error}}</div>
  {{/error}}

  <div class="form-card">
    <form method="post" action="/auth/register">
      <div class="form-group">
        <label for="name">Full name</label>
        <input id="name" name="name" type="text" required />
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required />
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input id="password" name="password" type="password" required minlength="8" />
      </div>
      <div class="form-group">
        <label for="membershipType">Membership type</label>
        <select id="membershipType" name="membershipType">
          <option value="full">Adult</option>
          <option value="student">Student (20% discount — requires verification)</option>
        </select>
      </div>
      <div class="form-actions">
        <button class="btn btn-primary" type="submit">Create account</button>
      </div>
      <p style="margin-top:1rem;font-size:0.875rem;color:var(--muted)">Already have an account? <a href="/auth/login">Login here</a></p>
    </form>
  </div>
</div>

{{> footer}}