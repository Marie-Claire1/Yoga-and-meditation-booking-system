{{> head}}
{{> header}}

<main class="container">
  <div class="confirmation-box">
    <div class="confirmation-icon">&#10003;</div>
    <h1>Booking confirmed</h1>
    <p class="subheading">Your place has been reserved.</p>

    <div class="card">
      <div class="card-body">
        <h2>{{booking.courseTitle}}</h2>
        {{#booking.isDropIn}}
        <p class="card-meta">Drop-in session: <strong>{{booking.sessionDetail}}</strong></p>
        {{/booking.isDropIn}}
        {{^booking.isDropIn}}
        <p class="card-meta">Full course enrolment</p>
        {{/booking.isDropIn}}
        <p class="card-meta">Status: <span class="badge badge-status-{{booking.status}}">{{booking.status}}</span></p>
        <p class="card-meta">Booked at: {{booking.createdAt}}</p>
      </div>
    </div>

    <div class="confirmation-actions">
      <a href="/bookings/my-bookings" class="btn btn-primary">View my bookings</a>
      <a href="/" class="btn">Back to courses</a>
    </div>
  </div>
</main>

{{> footer}}
