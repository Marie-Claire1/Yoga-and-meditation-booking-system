{{> head}}
{{> header}}

<main class="container">
  <div class="page-header">
    <h1>Sessions &mdash; {{course.title}}</h1>
    <div class="header-actions">
      <a href="/organiser/courses/{{course.id}}/sessions/new" class="btn btn-primary">+ Add session</a>
      <a href="/organiser" class="btn btn-sm">Back</a>
    </div>
  </div>

  {{#sessions}}
  <div class="card session-card">
    <div class="card-body">
      <div class="card-title-row">
        <p class="session-time"><strong>{{startDateTime}}</strong> &rarr; {{endDateTime}}</p>
        <span class="badge">{{bookedCount}}/{{capacity}} booked</span>
      </div>
      <p class="card-meta">{{location}}</p>
      <div class="card-actions">
        <a href="/organiser/courses/{{courseId}}/sessions/{{id}}/classlist" class="btn btn-sm">Class list</a>
        <a href="/organiser/courses/{{courseId}}/sessions/{{id}}/edit" class="btn btn-sm">Edit</a>
        <form action="/organiser/courses/{{courseId}}/sessions/{{id}}/delete" method="POST" class="inline-form"
          onsubmit="return confirm('Delete this session?')">
          <button type="submit" class="btn btn-sm btn-danger">Delete</button>
        </form>
      </div>
    </div>
  </div>
  {{/sessions}}

  {{^sessions}}
  <p class="empty-state">No sessions yet. <a href="/organiser/courses/{{course.id}}/sessions/new">Add one</a>.</p>
  {{/sessions}}
</main>

{{> footer}}