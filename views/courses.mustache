{{> head}}
{{> header}}

<div class="wrap">
  <div class="section-title" style="text-align:left;padding-top:2rem">
    <p class="section-eyebrow">Discover</p>
    <h1>All Courses</h1>
    <p>From weekly sessions to transformative weekend workshops — find the practice that speaks to you.</p>
  </div>

  <section class="filters">
    <form class="filter-form" method="get" action="/courses">
      <label>
        Level
        <select name="level">
          <option value="">Any</option>
          <option value="beginner">Beginner</option>
          <option value="intermediate">Intermediate</option>
          <option value="advanced">Advanced</option>
        </select>
      </label>
      <label>
        Type
        <select name="type">
          <option value="">Any</option>
          <option value="WEEKLY_BLOCK">Weekly block</option>
          <option value="WEEKEND_WORKSHOP">Weekend workshop</option>
        </select>
      </label>
      <label>
        Search
        <input type="search" name="q" value="{{filters.q}}" placeholder="Title or description" />
      </label>
      <button class="btn btn-sage" type="submit">Apply filters</button>
      <a class="btn" href="/courses">Show all</a>
    </form>
  </section>

  <div class="cards">
    {{#courses}}
    <article class="card">
      {{#image}}
      <div class="card-image">
        <img src="{{image}}" alt="{{title}}" loading="lazy">
        <span class="card-type-badge">{{type}}</span>
      </div>
      {{/image}}
      {{^image}}
      <div class="card-image-placeholder">🧘</div>
      {{/image}}
      <div class="card-body">
        <div class="card-level-price">
          <span class="level-badge {{level}}">{{level}}</span>
          <span class="card-price">&pound;{{price}}</span>
        </div>
        <h2><a href="/courses/{{id}}">{{title}}</a></h2>
        <p class="card-description">{{description}}</p>
        <p class="card-meta">📅 {{startDate}} &ndash; {{endDate}}</p>
        <p class="card-meta">📍 {{location}}</p>
        <p class="card-meta">🕐 {{sessionsCount}} session(s) &middot; Next: {{nextSession}}</p>
        {{#allowDropIn}}<p class="card-meta" style="color:var(--sage-dark)">✓ Drop-in: &pound;{{dropInPrice}}</p>{{/allowDropIn}}
        <div class="card-actions">
          <a href="/courses/{{id}}" class="btn btn-primary">View &amp; Book</a>
        </div>
      </div>
    </article>
    {{/courses}}

    {{#isEmpty}}
    <div class="empty-state">
      <p>No courses match your filters.</p>
      <a href="/courses" class="btn">Show all courses</a>
    </div>
    {{/isEmpty}}

    {{^courses}}
    {{^isEmpty}}
    <div class="empty-state">
      <p>No courses available yet.</p>
    </div>
    {{/isEmpty}}
    {{/courses}}
  </div>
</div>

{{> footer}}