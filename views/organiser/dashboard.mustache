{{> head}}
{{> header}}

<main class="container">
  <div class="page-header">
    <h1>Organiser dashboard</h1>
    <a href="/organiser/courses/new" class="btn btn-primary">+ Add course</a>
  </div>

  <section class="dashboard-section">
    <h2>Courses</h2>
    {{#courses}}
    <div class="card course-card">
      <div class="card-body">
        <div class="card-title-row">
          <h3>{{title}}</h3>
          <span class="badge badge-{{type}}">{{type}}</span>
        </div>
        <p class="card-meta">{{level}} &middot; {{instructorName}} &middot; {{startDate}} &ndash; {{endDate}}</p>
        <p class="card-meta">{{sessionsCount}} session(s) &middot; &pound;{{price}}
          {{#allowDropIn}}&middot; Drop-in: &pound;{{dropInPrice}}{{/allowDropIn}}
        </p>
        <div class="card-actions">
          <a href="/organiser/courses/{{id}}/sessions" class="btn btn-sm">Sessions</a>
          <a href="/organiser/courses/{{id}}/edit" class="btn btn-sm">Edit</a>
          <form action="/organiser/courses/{{id}}/delete" method="POST" class="inline-form"
            onsubmit="return confirm('Delete this course and all its sessions?')">
            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
          </form>
        </div>
      </div>
    </div>
    {{/courses}}
    {{^courses}}
    <p class="empty-state">No courses yet. <a href="/organiser/courses/new">Add one</a>.</p>
    {{/courses}}
  </section>

  <section class="dashboard-section">
    <div class="section-header">
      <h2>Users</h2>
      <a href="/organiser/users" class="btn btn-sm">Manage users</a>
    </div>
  </section>
</main>

{{> footer}}